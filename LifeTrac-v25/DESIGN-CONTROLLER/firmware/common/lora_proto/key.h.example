#ifndef LIFETRAC_LORA_KEY_H
#define LIFETRAC_LORA_KEY_H

#include <stdint.h>

// Copy this file to key.h on each controller/base build host and replace the
// bytes with the fleet key generated by tools/provision.py. key.h is ignored by
// git so production credentials do not enter the repository.

#define LIFETRAC_KEY_ID 0x00000001UL
#define LIFETRAC_FLEET_KEY_BYTES \
    { 0x00, 0x00, 0x00, 0x00, \
      0x00, 0x00, 0x00, 0x00, \
      0x00, 0x00, 0x00, 0x00, \
      0x00, 0x00, 0x00, 0x00 }

#endif