[Unit]
Description=LifeTrac v25 base station (compose stack)
After=network-online.target docker.service
Requires=docker.service
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/lifetrac/DESIGN-CONTROLLER
EnvironmentFile=/opt/lifetrac/DESIGN-CONTROLLER/.env
ExecStart=/usr/bin/docker compose up -d --build --remove-orphans
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
